<!DOCTYPE html>
<html lang="en">

<%- include("partials/head", {
    title: "Edit Product"
}) %>

<body>

<%- include("partials/navbar") %>

<div class="container">

    <h1>Edit Product</h1>

    <form action="/product/<%= product._id %>?_method=PATCH" method="POST">

        <div class="row mb-3 align-items-center">
            <div class="row">
                <label class="col-md-3 col-form-label">Product Title</label>
                <div class="col-md-9">
                    <input class="form-control" type="text" value="<%= product.title %>" name="title" placeholder="Product Title" required />
                </div>
            </div>
            <div class="row">
                <label class="col-md-3 col-form-label">Sku</label>
                <div class="col-md-9">
                    <input class="form-control" type="text" value="<%= product.sku %>" name="sku" placeholder="SKU" required />
                </div>
            </div>
            <div class="row">
                <label class="col-md-3 col-form-label">MRP</label>
                <div class="col-md-9">
                    <input type="number" class="form-control" value="<%= product.mrp %>" name="mrp" placeholder="MRP" required />
                </div>
            </div>
            <div class="row">
                <label class="col-md-3 col-form-label">Sale Price</label>
                <div class="col-md-9">
                    <input type="number" class="form-control" value="<%= product.salePrice %>" name="salePrice" placeholder="Sale Price" required />
                </div>
            </div>
            <div class="row">
                <label class="col-md-3 col-form-label">Stock</label>
                <div class="col-md-9">
                    <input type="number" class="form-control" value="<%= product.stock %>" name="stock" placeholder="Stock" />
                </div>
            </div>
            <div class="row">

        <!-- JEWELLERY -->
                <label class="col-md-3 col-form-label">Product Weight</label>
                <div class="col-md-9">
                    <input class="form-control" step="0.01" type="number" value="<%= product.productWeight %>" name="productWeight" placeholder="Product Weight" required />
                </div>
            </div>
            <div class="row">
                <label class="col-md-3 col-form-label">Metal Weight</label>
                <div class="col-md-9">
                    <input class="form-control" step="0.01" type="number" value="<%= product.metalWeight %>" name="metalWeight" placeholder="Metal Weight" required />
                </div>
            </div>

            <div class="row">

                <div class="col-md-6">
                    <select name="metalType">

                        <option value="">Select Metal</option>

                        <option value="Gold" <%= product.metalType === "Gold" ? "selected": "" %> >Gold</option>

                        <option value="Rose Gold" <%= product.metalType === "Rose Gold" ? "selected": "" %> >Rose Gold</option>

                        <option value="Yellow Gold" <%= product.metalType === "Yellow Gold" ? "selected": "" %> >Yellow Gold</option>

                        <option value="White Gold" <%= product.metalType === "White Gold" ? "selected": "" %> >White Gold</option>

                        <option value="Silver" <%= product.metalType === "Silver" ? "selected": "" %>>Silver</option>

                        <option value="Platinum" <%= product.metalType === "Platinum" ? "selected": "" %>>Platinum</option>

                    </select>
                </div>
            

                <div class="col-md-6">
                    <select name="purity">

                        <option value="">Select Purity</option>

                        <option value="14K" <%= product.purity === "14K" ? "selected": "" %>>14K</option>

                        <option value="18K" <%= product.purity === "18K" ? "selected": "" %>>18K</option>

                        <option value="22K" <%= product.purity === "22K" ? "selected": "" %>>22K</option>

                        <option value="24K" <%= product.purity === "24K" ? "selected": "" %>>24K</option>

                        <option value="999" <%= product.purity === "999" ? "selected": "" %>>999</option>

                        <option value="925" <%= product.purity === "925" ? "selected": "" %>>925</option>

                    </select>
                </div>
            </div>
            <div class="row">
                <label class="col-md-3 col-form-label">Making Charges</label>
                <div class="col-md-9">
                    <input type="number" class="form-control" value="<%= product.makingCharges %>" name="makingCharges" placeholder="Making Charges" />
                </div>
            </div>


        <h3>Stone Details</h3>
        <p><small>(Use comma separation for arrays if multiple stones, though standard form submission for arrays typically uses multiple inputs or custom JS. Assuming text inputs that will be parsed as arrays in the controller)</small></p>

        <div class="row">
            <label class="col-md-3 col-form-label">Stone Type</label>
            <div class="col-md-9">
                <input class="form-control" type="text" value="<%= product.stoneType || '' %>" name="stoneType" placeholder="Stone Type" />
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Stone Shape</label>
            <div class="col-md-9">
                <input class="form-control" type="text" 
                    value="<%= Array.isArray(product.stoneShape) ? product.stoneShape.join(', ') : (product.stoneShape || '') %>"
                    name="stoneShape" placeholder="Stone Shapes (comma separated)" />
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Stone Price</label>
            <div class="col-md-9">
                <input class="form-control" type="text" 
                    value="<%= Array.isArray(product.stonePrice) ? product.stonePrice.join(', ') : (product.stonePrice || '') %>"
                    name="stonePrice" placeholder="Stone Prices (comma separated)" />
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Stone Weight</label>
            <div class="col-md-9">
                <input class="form-control" type="text" 
                    value="<%= Array.isArray(product.stoneWeight) ? product.stoneWeight.join(', ') : (product.stoneWeight || '') %>"
                    name="stoneWeight" placeholder="Stone Weights (comma separated)" />
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Stone Color</label>
            <div class="col-md-9">
                <input class="form-control" type="text" 
                    value="<%= Array.isArray(product.stoneColor) ? product.stoneColor.join(', ') : (product.stoneColor || '') %>"
                    name="stoneColor" placeholder="Stone Colors (comma separated)" />
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Stone Clarity</label>
            <div class="col-md-9">
                <input class="form-control" type="text"
                    value="<%= Array.isArray(product.stoneClarity) ? product.stoneClarity.join(', ') : (product.stoneClarity || '') %>"
                    name="stoneClarity" placeholder="Stone Clarities (comma separated)" />
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Stone Size Range</label>
            <div class="col-md-9">
                <input class="form-control" type="text"
                value="<%= Array.isArray(product.stoneSizeRange) ? product.stoneSizeRange.join(', ') : (product.stoneSizeRange || '') %>"
                name="stoneSizeRange" placeholder="Stone Size Ranges (comma separated)" />
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Short Description</label>
            <div class="col-md-9">
                <textarea class="form-control" name="shortDescription" placeholder="Short Description"><%= product.shortDescription %></textarea>
            </div>
        </div>

        <div class="row">
            <label class="col-md-3 col-form-label">Full Description</label>
            <div class="col-md-9">
                <textarea class="form-control" name="description" placeholder="Full Description"><%= product.description %></textarea>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-3 col-form-label">Images</label>
            <div class="col-md-9">
                <div id="image-container">

                    <% product.images.forEach(image => { %>

                        <div class="input-group mb-2">
                            <input class="form-control" type="text" name="images" value="<%= image %>" />
                            <button class="btn btn-danger" type="button" onclick="removeField(this)">
                                Remove
                            </button>
                        </div>

                    <% }) %>

                </div>

                <button class="btn btn-outline-primary mt-2" type="button" onclick="addImageField()">
                    Add Image
                </button>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-3 col-form-label">Videos</label>
            <div class="col-md-9">
                <div id="video-container">

                    <% product.videos.forEach(video => { %>

                        <div class="input-group mb-2">
                            <input class="form-control" type="text" name="videos" value="<%= video %>" />
                            <button class="btn btn-danger" type="button" onclick="removeField(this)">
                                Remove
                            </button>
                        </div>

                    <% }) %>

                </div>

                <button class="btn btn-outline-primary mt-2" type="button" onclick="addVideoField()">
                    Add Video
                </button>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-3 col-form-label">Customization Fields</label>

            <div class="col-md-9">
                <div id="customization-container">

                    <% product.customizationFields.forEach((field, index) => { %>

                        <div class="card mb-3">
                            <div class="card-body">

                                <input class="form-control mb-2" type="text"
                                    name="customizationFields[<%= index %>][name]"
                                    value="<%= field.name %>"
                                    placeholder="Field Name" />

                                <input class="form-control mb-2" type="text"
                                    name="customizationFields[<%= index %>][label]"
                                    value="<%= field.label %>"
                                    placeholder="Field Label" />

                                <select class="form-select mb-2"
                                    name="customizationFields[<%= index %>][type]">

                                    <option value="text" <%= field.type==="text" ? "selected" : "" %>>
                                        Text
                                    </option>

                                    <option value="number" <%= field.type==="number" ? "selected" : "" %>>
                                        Number
                                    </option>

                                    <option value="select" <%= field.type==="select" ? "selected" : "" %>>
                                        Select
                                    </option>

                                </select>

                                <input class="form-control mb-2" type="text"
                                    name="customizationFields[<%= index %>][options]"
                                    value="<%= Array.isArray(field.options) ? field.options.join(', ') : field.options || '' %>"
                                    placeholder="Options" />

                                <input class="form-control mb-2" type="text"
                                    name="customizationFields[<%= index %>][placeholder]"
                                    value="<%= field.placeholder || '' %>"
                                    placeholder="Placeholder" />

                                <input class="form-control mb-2" type="text"
                                    name="customizationFields[<%= index %>][dependsOn][field]"
                                    value="<%= field.dependsOn?.field || '' %>"
                                    placeholder="Depends On Field" />

                                <input class="form-control mb-2" type="text"
                                    name="customizationFields[<%= index %>][dependsOn][value]"
                                    value="<%= field.dependsOn?.value || '' %>"
                                    placeholder="Depends On Value" />

                                <div class="form-check mb-3">
                                    <input class="form-check-input"
                                        type="checkbox"
                                        name="customizationFields[<%= index %>][required]"
                                        <%= field.required ? "checked" : "" %>>

                                    <label class="form-check-label">
                                        Required
                                    </label>
                                </div>

                                <button class="btn btn-danger"
                                    type="button"
                                    onclick="removeField(this)">
                                    Remove Field
                                </button>

                            </div>
                        </div>

                    <% }) %>

                </div>

                <button class="btn btn-outline-success"
                    type="button"
                    onclick="addCustomizationField()">
                    Add Customization
                </button>
            </div>
        </div>

        <div class="row">
            <div class="offset-md-3 col-md-9">
                <button class="btn btn-success btn-lg w-100" type="submit">
                    Update Product
                </button>
            </div>
        </div>
    </div>

    </form>

</div>

<script>

    let fieldIndex =
        <%= product.customizationFields.length %>;

</script>

<script src="/js/edit-product.js"></script>

</body>

</html>